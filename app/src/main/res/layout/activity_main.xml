<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#121212"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/tvResult"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:text="0"
        android:textSize="36sp"
        android:textColor="#FFFFFF"
        android:gravity="end|center_vertical"
        android:background="#1E1E1E"
        android:padding="16dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:layout_marginTop="20dp">

        <Button android:text="7" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="8" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="9" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="/" android:onClick="onOperatorClick" style="@style/btnOp"/>

        <Button android:text="4" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="5" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="6" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="*" android:onClick="onOperatorClick" style="@style/btnOp"/>

        <Button android:text="1" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="2" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="3" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="-" android:onClick="onOperatorClick" style="@style/btnOp"/>

        <Button android:text="0" android:onClick="onNumberClick" style="@style/btnNum"/>
        <Button android:text="C" android:onClick="onClearClick" style="@style/btnOp"/>
        <Button android:text="=" android:onClick="onEqualClick" style="@style/btnOp"/>
        <Button android:text="+" android:onClick="onOperatorClick" style="@style/btnOp"/>

    </GridLayout>

</LinearLayout>